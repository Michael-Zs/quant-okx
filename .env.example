# ===== OKX API（去 https://www.okx.com/account/my-api 申请）=====
# 模拟盘 key：登录后切到「模拟交易」再申请；实盘 key：在「实盘」申请
OKX_API_KEY=your_api_key
OKX_API_SECRET=your_api_secret
OKX_API_PASSPHRASE=your_passphrase

# ===== REST API 访问令牌 =====
# 控制接口（启停实盘、触发回测）需要这个 token；客户端在 header 传 X-API-Token
API_TOKEN=change_me_to_a_long_random_string

# ===== 默认交易参数 =====
DEFAULT_LEVERAGE=5
DEFAULT_POSITION_RATIO=0.1
DEFAULT_FEE=0.0005
DEFAULT_SLIPPAGE=0.0005

# ===== 服务端口 =====
API_HOST=0.0.0.0
API_PORT=8787
